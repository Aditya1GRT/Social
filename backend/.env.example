# Backend environment variables
# Copy to .env and adjust for your environment.

# Port the server listens on
PORT=5000

# Secret used to sign JWT tokens — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# How long issued tokens stay valid
JWT_EXPIRES_IN=7d

# Public base URL of this backend (used to build LOCAL uploaded-file URLs).
# Leave unset to auto-detect from the incoming request.
# PUBLIC_URL=https://your-backend.onrender.com

# Durable file storage (recommended for production / ephemeral hosts).
# When set, uploads go to Cloudinary instead of the local ./uploads folder.
# Get this value from your Cloudinary dashboard.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@your-cloud
