# Backend environment variables
# Copy to .env and adjust for your environment.

PORT=5000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (REQUIRED for persistent data on Render).
# Without this, NeDB is used and all data is lost on every process restart.
#
# Free cluster: https://cloud.mongodb.com → New Project → Free M0 tier
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/social-scoop?retryWrites=true&w=majority

# ── File uploads ─────────────────────────────────────────────────────────────
# Durable uploads (recommended). Format: cloudinary://<key>:<secret>@<cloud>
# CLOUDINARY_URL=cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@your-cloud

# Base URL for building local upload file links (auto-detected if unset)
# PUBLIC_URL=https://your-backend.onrender.com
